# Codelo — API keys cho các nhà cung cấp mô hình
# Bỏ comment và điền key bạn muốn dùng

# DeepSeek (mặc định)
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# OpenAI
# OPENAI_API_KEY=sk-your-openai-key

# Google Gemini
# GOOGLE_API_KEY=your-google-ai-key

# Ngôn ngữ giao diện: vi, en, zh (mặc định: auto-detect)
CODELO_LANG=vi